{
  "name": "nowledge-mem",
  "version": "0.2.1",
  "description": "Cross-tool memory for Kimi Code. Recall past decisions, search prior threads, and keep Kimi Code sessions searchable in Nowledge Mem.",
  "keywords": ["memory", "mcp", "skills", "thread-sync"],
  "author": {
    "name": "Nowledge Labs"
  },
  "homepage": "https://mem.nowledge.co/docs/integrations/kimi-code",
  "license": "MIT",
  "skills": "./nowledge-mem-kimi-code-plugin/skills/",
  "sessionStart": {
    "skill": "nowledge-mem"
  },
  "skillInstructions": "Use Nowledge Mem for durable cross-tool memory. Prefer MCP tools when they are connected; use nmem CLI as the fallback and for real Kimi Code transcript import. If nmem exists but rejects Kimi Code commands or MCP host helpers, treat it as outdated and upgrade the CLI before retrying.",
  "commands": "./nowledge-mem-kimi-code-plugin/commands/",
  "mcpServers": {
    "nowledge-mem": {
      "url": "http://127.0.0.1:14242/mcp/",
      "type": "streamableHttp",
      "enabled": true
    }
  },
  "hooks": [
    {
      "event": "Stop",
      "command": "python3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || python ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || py -3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py",
      "timeout": 40
    },
    {
      "event": "SessionEnd",
      "command": "python3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || python ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || py -3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py",
      "timeout": 40
    },
    {
      "event": "PreCompact",
      "command": "python3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || python ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || py -3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py",
      "timeout": 40
    },
    {
      "event": "SubagentStop",
      "command": "python3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || python ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || py -3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py",
      "timeout": 40
    },
    {
      "event": "Interrupt",
      "command": "python3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || python ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py || py -3 ./nowledge-mem-kimi-code-plugin/scripts/kimi-sync-hook.py",
      "timeout": 40
    }
  ],
  "interface": {
    "displayName": "Nowledge Mem",
    "shortDescription": "Memory that follows you across Kimi Code and your other AI tools",
    "longDescription": "Loads startup context, guides memory retrieval and distillation, exposes quick slash commands, and syncs Kimi Code conversations into Nowledge Mem threads through native plugin lifecycle hooks.",
    "developerName": "Nowledge Labs",
    "websiteURL": "https://mem.nowledge.co"
  }
}

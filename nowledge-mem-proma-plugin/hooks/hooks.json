{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PROMA_HOME}/hooks/save-to-nmem.py\"",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PROMA_HOME}/hooks/read-working-memory.py\"",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
